---
/**
 * NFC bookmark landing page — one page per physical bookmark in the series
 * 《我还是昨天的我吗》 (ISSUE 03 · 预热 Preheat 2026). Reached by NFC tap or
 * QR scan at /b/[id]. Self-contained: mobile-first single card, no site
 * chrome, no scripts, noindex; the visual continues the printed bookmark's
 * cataloguing language. Colors come from the --bm-* tokens (tokens.css).
 */
import '../../styles/tokens.css';
import { bookmarks } from '../../data/bookmarks';

export function getStaticPaths() {
  return bookmarks.map((b) => ({ params: { id: b.id }, props: { b } }));
}

const { b } = Astro.props;
const total = String(bookmarks.length).padStart(2, '0');
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{b.quote_cn} — 我还是昨天的我吗 · SSPCZ 2026</title>
  </head>
  <body>
    <main class="wrap">
      <article class="card">
        <div class="card__in">
          <header class="card__top">浙江中学生哲学大会 —— ISSUE 03</header>

          <p class="card__section">{b.section}</p>

          <h1 class="card__name">
            {b.name_cn}
            <span class="card__name-en">{b.name_en}</span>
          </h1>
          <p class="card__meta">{b.meta}</p>

          <blockquote class="card__quote">
            <p class="card__quote-cn">「{b.quote_cn}」</p>
            {b.quote_en && <p class="card__quote-en">{b.quote_en}</p>}
          </blockquote>
          <p class="card__source">{b.source}</p>

          <p class="card__context">{b.context}</p>

          <footer class="card__foot">
            <span>预热 · Preheat 2026</span>
            <span class="card__page">{b.no} / {total}</span>
          </footer>
          <p class="card__link">
            <a href="/">浙江中学生哲学大会 · 变与不变 →</a>
          </p>
        </div>
      </article>
    </main>
  </body>
</html>

<style>
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    background: var(--bm-paper);
    color: var(--bm-ink);
    font-family: 'Noto Serif SC', 'Source Han Serif SC', serif;
  }

  .wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100svh;
    padding: 1.5rem 1rem;
  }

  /* The card — a printed panel with hairline edge and crop-mark corners. */
  .card {
    position: relative;
    width: 100%;
    max-width: 26rem;
    background: var(--surface-primary);
    border: 1px solid var(--bm-line);
  }

  .card__in {
    position: relative;
    padding: 1.75rem 1.6rem 1.5rem;
  }

  /* Crop marks: four short corner ticks just outside the panel edge. */
  .card::before,
  .card::after,
  .card__in::before,
  .card__in::after {
    position: absolute;
    width: 0.75rem;
    height: 0.75rem;
    content: '';
  }

  .card::before {
    top: -5px;
    left: -5px;
    border-top: 1px solid var(--bm-accent);
    border-left: 1px solid var(--bm-accent);
  }

  .card::after {
    top: -5px;
    right: -5px;
    border-top: 1px solid var(--bm-accent);
    border-right: 1px solid var(--bm-accent);
  }

  .card__in::before {
    bottom: -5px;
    left: -5px;
    border-bottom: 1px solid var(--bm-accent);
    border-left: 1px solid var(--bm-accent);
  }

  .card__in::after {
    right: -5px;
    bottom: -5px;
    border-right: 1px solid var(--bm-accent);
    border-bottom: 1px solid var(--bm-accent);
  }

  .card__top {
    padding-bottom: 0.7rem;
    border-bottom: 1px solid var(--bm-line);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    color: var(--bm-accent);
  }

  .card__section {
    margin-top: 1.15rem;
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .card__name {
    margin-top: 0.55rem;
    font-size: 1.9rem;
    font-weight: 700;
    line-height: 1.25;
    color: var(--bm-ink);
  }

  .card__name-en {
    margin-left: 0.4rem;
    font-family: Georgia, serif;
    font-size: 1.02rem;
    font-style: italic;
    font-weight: 400;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .card__meta {
    margin-top: 0.4rem;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
  }

  .card__quote {
    margin-top: 1.4rem;
  }

  .card__quote-cn {
    font-size: 1.35rem;
    line-height: 1.75;
    color: var(--bm-ink);
  }

  .card__quote-en {
    margin-top: 0.6rem;
    font-family: Georgia, serif;
    font-size: 0.85rem;
    font-style: italic;
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  .card__source {
    margin-top: 0.8rem;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    color: var(--color-text-muted);
  }

  .card__context {
    margin-top: 1.15rem;
    padding-top: 1.15rem;
    border-top: 1px solid var(--bm-line);
    font-size: 0.95rem;
    line-height: 1.9;
    color: var(--color-text);
  }

  .card__foot {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-top: 1.5rem;
    padding-top: 0.8rem;
    border-top: 1px solid var(--bm-line);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    color: var(--color-text-muted);
  }

  .card__page {
    font-family: Georgia, serif;
    letter-spacing: 0.12em;
  }

  .card__link {
    margin-top: 0.9rem;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-align: center;
  }

  .card__link a {
    color: var(--bm-accent);
    text-decoration: none;
    border-bottom: 1px solid var(--bm-line);
    padding-bottom: 0.1rem;
  }

  .card__link a:hover {
    border-bottom-color: var(--bm-accent);
  }
</style>
