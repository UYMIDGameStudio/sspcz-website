---
/**
 * Series index for the NFC bookmark set 《我还是昨天的我吗》 — lists the
 * seven bookmarks (section · name · first line of the quote) and links to
 * each landing page. Same self-contained visual language as /b/[id].
 */
import '../../styles/tokens.css';
import { bookmarks } from '../../data/bookmarks';

/** First sentence of the Chinese quote, punctuation kept. */
const firstSentence = (s: string): string => {
  const m = s.match(/^.*?[。?？!！;；]/);
  return m ? m[0] : s;
};
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>我还是昨天的我吗 — SSPCZ 2026 书签系列</title>
  </head>
  <body>
    <main class="wrap">
      <article class="card">
        <div class="card__in">
          <header class="card__top">浙江中学生哲学大会 —— ISSUE 03</header>

          <h1 class="card__title">《我还是昨天的我吗》</h1>
          <p class="card__subtitle">书签系列 · 七张 · 预热 Preheat 2026</p>

          <ol class="list">
            {
              bookmarks.map((b) => (
                <li class="list__item">
                  <a class="list__link" href={`/b/${b.id}`}>
                    <span class="list__no">{b.no}</span>
                    <span class="list__body">
                      <span class="list__section">{b.section}</span>
                      <span class="list__name">
                        {b.name_cn}
                        <span class="list__name-en">{b.name_en}</span>
                      </span>
                      <span class="list__quote">「{firstSentence(b.quote_cn)}」</span>
                    </span>
                  </a>
                </li>
              ))
            }
          </ol>

          <footer class="card__foot">
            <span>预热 · Preheat 2026</span>
            <span class="card__page">07 / 07</span>
          </footer>
          <p class="card__link">
            <a href="/">浙江中学生哲学大会 · 变与不变 →</a>
          </p>
        </div>
      </article>
    </main>
  </body>
</html>

<style>
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    background: var(--bm-paper);
    color: var(--bm-ink);
    font-family: 'Noto Serif SC', 'Source Han Serif SC', serif;
  }

  .wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100svh;
    padding: 1.5rem 1rem;
  }

  .card {
    position: relative;
    width: 100%;
    max-width: 26rem;
    background: var(--surface-primary);
    border: 1px solid var(--bm-line);
  }

  .card__in {
    position: relative;
    padding: 1.75rem 1.6rem 1.5rem;
  }

  .card::before,
  .card::after,
  .card__in::before,
  .card__in::after {
    position: absolute;
    width: 0.75rem;
    height: 0.75rem;
    content: '';
  }

  .card::before {
    top: -5px;
    left: -5px;
    border-top: 1px solid var(--bm-accent);
    border-left: 1px solid var(--bm-accent);
  }

  .card::after {
    top: -5px;
    right: -5px;
    border-top: 1px solid var(--bm-accent);
    border-right: 1px solid var(--bm-accent);
  }

  .card__in::before {
    bottom: -5px;
    left: -5px;
    border-bottom: 1px solid var(--bm-accent);
    border-left: 1px solid var(--bm-accent);
  }

  .card__in::after {
    right: -5px;
    bottom: -5px;
    border-right: 1px solid var(--bm-accent);
    border-bottom: 1px solid var(--bm-accent);
  }

  .card__top {
    padding-bottom: 0.7rem;
    border-bottom: 1px solid var(--bm-line);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    color: var(--bm-accent);
  }

  .card__title {
    margin-top: 1.2rem;
    font-size: 1.55rem;
    font-weight: 700;
    line-height: 1.4;
    color: var(--bm-ink);
  }

  .card__subtitle {
    margin-top: 0.4rem;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .list {
    margin-top: 1.3rem;
    list-style: none;
  }

  .list__item {
    border-top: 1px solid var(--bm-line);
  }

  .list__item:last-child {
    border-bottom: 1px solid var(--bm-line);
  }

  .list__link {
    display: flex;
    gap: 0.9rem;
    padding: 0.85rem 0.2rem;
    color: inherit;
    text-decoration: none;
  }

  .list__no {
    font-family: Georgia, serif;
    font-size: 0.95rem;
    color: var(--bm-accent);
    letter-spacing: 0.08em;
  }

  .list__section {
    display: block;
    font-size: 0.66rem;
    letter-spacing: 0.2em;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .list__name {
    display: block;
    margin-top: 0.25rem;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--bm-ink);
  }

  .list__name-en {
    margin-left: 0.35rem;
    font-family: Georgia, serif;
    font-size: 0.8rem;
    font-style: italic;
    font-weight: 400;
    color: var(--color-text-muted);
  }

  .list__quote {
    display: block;
    margin-top: 0.3rem;
    font-size: 0.85rem;
    line-height: 1.7;
    color: var(--color-text);
  }

  .list__link:hover .list__name {
    color: var(--bm-accent);
  }

  .card__foot {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-top: 1.4rem;
    padding-top: 0.8rem;
    border-top: 1px solid var(--bm-line);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    color: var(--color-text-muted);
  }

  .card__page {
    font-family: Georgia, serif;
    letter-spacing: 0.12em;
  }

  .card__link {
    margin-top: 0.9rem;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-align: center;
  }

  .card__link a {
    padding-bottom: 0.1rem;
    color: var(--bm-accent);
    text-decoration: none;
    border-bottom: 1px solid var(--bm-line);
  }

  .card__link a:hover {
    border-bottom-color: var(--bm-accent);
  }
</style>
