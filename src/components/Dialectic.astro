---
/**
 * Component (semantic, stateless): a voiced utterance in a dialogue
 * (RFC-300 §2.3). Voices are distinguished by spatial tension — alignment
 * and indentation — never by chat bubbles. Citations follow RFC-200 §2.
 */
interface Props {
  voice?: 'thesis' | 'antithesis';
  cite?: string;
}

const { voice = 'thesis', cite } = Astro.props;
---

<blockquote class:list={['dialectic', `dialectic--${voice}`]}>
  <div class="dialectic__utterance">
    <slot />
  </div>
  {cite && <footer class="dialectic__cite">{cite}</footer>}
</blockquote>

<style>
  .dialectic {
    margin: 0;
    padding: var(--space-4) var(--space-6);
    background: var(--color-paper-inset);
  }

  .dialectic--thesis {
    border-left: 2px solid var(--color-accent);
  }

  .dialectic--antithesis {
    margin-left: var(--space-12);
    text-align: right;
    border-right: 2px solid var(--color-accent);
  }

  .dialectic__utterance {
    font-family: var(--font-serif-cjk);
    line-height: var(--leading-loose);
    color: var(--color-ink);
  }

  .dialectic__cite {
    margin-top: var(--space-2);
    font-size: var(--type-marginalia);
    /* Contrast guard (ADR-003 §3.8): the cite sits on --surface-secondary,
       where muted grey drops below AA — use the readable text ink. */
    color: var(--color-text);
  }
</style>
