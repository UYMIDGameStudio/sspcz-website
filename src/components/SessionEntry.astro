---
/**
 * Component (semantic, stateless): one program session. Speaker-voiced
 * sessions (student papers, demos) and guest-voiced sessions (lectures)
 * render their abstract through the Dialectic component, mapped from the
 * extracted `kind` field; ceremonial/plenary sessions stay unvoiced.
 */
import Dialectic from './Dialectic.astro';
import type { Locale, Session } from '../lib/issueData';

interface Props {
  session: Session;
  locale: Locale;
}

const { session, locale } = Astro.props;

const VOICES: Partial<Record<Session['kind'], 'thesis' | 'antithesis'>> = {
  papers: 'thesis',
  demo: 'thesis',
  lecture: 'antithesis',
};
const voice = VOICES[session.kind];
---

<article class="session">
  <p class="session__time">
    <time>{session.timeStart}</time>
    <span aria-hidden="true">–</span>
    <time>{session.timeEnd}</time>
  </p>
  <p class="session__kind">{session.kindLabel[locale]}</p>
  <div class="session__matter">
    <h3 class="session__title">{session.title[locale]}</h3>
    {
      voice ? (
        <Dialectic voice={voice}>{session.abstract[locale]}</Dialectic>
      ) : (
        <p class="session__abstract">{session.abstract[locale]}</p>
      )
    }
  </div>
</article>

<style>
  .session {
    display: grid;
    grid-template-columns: 8rem 6rem 1fr;
    gap: var(--space-6);
    align-items: baseline;
    padding: var(--space-6) 0;
    border-bottom: 1px solid var(--color-line);
  }

  .session__time {
    font-family: var(--font-serif-latin);
    font-size: var(--text-base);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .session__kind {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .session__title {
    font-size: var(--text-md);
  }

  .session__matter > :global(.dialectic) {
    margin-top: var(--space-3);
  }

  .session__abstract {
    margin-top: var(--space-3);
    color: var(--color-text-muted);
    line-height: var(--leading-loose);
  }

  @media (width <= 56.25em) {
    .session {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }
</style>
