---
/**
 * Pattern (layout-level): persistent publication metadata framing the
 * viewport like a physical journal page (RFC-300 §2.4). The masthead pairs
 * the official SSPCZ logo with the publication wordmark; the year is
 * chronological metadata drawn from issue frontmatter (ADR-001 §2.1).
 */
interface Props {
  publication: string;
  issue: string;
  year: number | string;
  homeHref?: string;
  logoSrc?: string;
}

const { publication, issue, year, homeHref, logoSrc } = Astro.props;
const Tag = homeHref ? 'a' : 'span';
---

<header class="running-header">
  <Tag class="running-header__brand" href={homeHref}>
    {logoSrc && <img class="running-header__logo" src={logoSrc} alt={publication} width="120" height="27" />}
    <span class="running-header__wordmark" aria-hidden="true">{publication}</span>
  </Tag>
  <nav class="running-header__nav" aria-label="Site">
    <slot />
  </nav>
  <span class="running-header__issue">{issue} · {year}</span>
</header>

<style>
  .running-header {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    display: flex;
    gap: var(--space-6);
    align-items: center;
    justify-content: space-between;
    padding: var(--space-3) var(--page-gutter);
    font-family: var(--font-serif-latin);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-muted);
    background: var(--color-paper);
    border-bottom: 1px solid var(--color-line);
  }

  /* Named with the block prefix (not `.masthead`) to avoid colliding with the
     page-level `.masthead` in global.css, whose padding + border-bottom would
     otherwise land on this header brand link. */
  .running-header__brand {
    display: inline-flex;
    gap: var(--space-3);
    align-items: center;
    color: var(--color-ink);
    white-space: nowrap;
  }

  .running-header__logo {
    display: block;
    width: auto;
    height: 1.7em;
    mix-blend-mode: multiply;
  }

  .running-header__wordmark {
    white-space: nowrap;
  }

  .running-header__issue {
    white-space: nowrap;
  }

  .running-header__nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-6);
    align-items: center;
  }

  @media (width <= 56.25em) {
    .running-header {
      flex-wrap: wrap;
      padding: var(--space-3) var(--page-gutter-narrow);
    }

    /* The wordmark is verbose on small screens; the logo carries identity. */
    .running-header__logo + .running-header__wordmark {
      display: none;
    }
  }
</style>
