---
/**
 * Pattern (layout-level): persistent publication masthead framing the viewport
 * like a physical journal page (RFC-300 §2.4). Renders the name-primary brand
 * lockup (ADR-003 §3.2): the official SSPCZ logo beside a stacked wordmark —
 * the institution's name as the primary line, with the acronym + founding year
 * as a subordinate tertiary tag. The issue mark is chronological metadata drawn
 * from issue frontmatter (ADR-001 §2.1).
 */
interface Props {
  /** Primary identity line (native name in zh; the acronym in en). */
  primary: string;
  /** Subordinate tertiary tag (acronym · since-year in zh; full name in en). */
  secondary: string;
  issue: string;
  year: number | string;
  homeHref?: string;
  logoSrc?: string;
}

const { primary, secondary, issue, year, homeHref, logoSrc } = Astro.props;
const Tag = homeHref ? 'a' : 'span';
---

<header class="running-header">
  <Tag class="running-header__brand" href={homeHref}>
    {logoSrc && <img class="running-header__logo" src={logoSrc} alt="" width="120" height="42" />}
    <span class="running-header__lockup">
      <span class="running-header__wordmark">{primary}</span>
      <span class="running-header__tag">{secondary}</span>
    </span>
  </Tag>
  <nav class="running-header__nav" aria-label="Site">
    <slot />
  </nav>
  <span class="running-header__issue">{issue} · {year}</span>
</header>

<style>
  .running-header {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    display: flex;
    gap: var(--space-6);
    align-items: center;
    justify-content: space-between;
    padding: var(--space-3) var(--page-gutter);
    font-family: var(--font-serif-latin);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-muted);
    background: var(--color-paper);
    border-bottom: 1px solid var(--color-line);
  }

  /* Named with the block prefix (not `.masthead`) to avoid colliding with the
     page-level `.masthead` in global.css, whose padding + border-bottom would
     otherwise land on this header brand link. */
  .running-header__brand {
    display: inline-flex;
    gap: var(--space-3);
    align-items: center;
    color: var(--color-ink);
    white-space: nowrap;
  }

  .running-header__logo {
    display: block;
    width: auto;
    height: 2.5rem;
    mix-blend-mode: multiply;
  }

  .running-header__lockup {
    display: inline-flex;
    flex-direction: column;
    gap: 0.15rem;
    line-height: var(--leading-tight);
  }

  /* Primary line: the institution name. CJK by default; Latin under :lang(en). */
  .running-header__wordmark {
    font-family: var(--font-serif-cjk);
    font-size: var(--text-md);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink);
    white-space: nowrap;
  }

  :global(html:lang(en)) .running-header__wordmark {
    font-family: var(--font-serif-latin);
  }

  /* Tertiary tag: --color-text-muted (not the fainter mock grey) keeps it AA
     legible at this size while staying subordinate to the name. */
  .running-header__tag {
    font-family: var(--font-serif-latin);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wider);
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .running-header__issue {
    white-space: nowrap;
  }

  .running-header__nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-6);
    align-items: center;
  }

  @media (width <= 56.25em) {
    .running-header {
      flex-wrap: wrap;
      padding: var(--space-3) var(--page-gutter-narrow);
    }

    /* The tertiary tag is verbose on small screens; the name + logo carry
       identity. */
    .running-header__tag {
      display: none;
    }
  }
</style>
