---
import '../styles/tokens.css';
import '../styles/global.css';
import type { Locale } from '../lib/issueData';

interface Props {
  title: string;
  description?: string;
  lang?: Locale;
  /** Absolute URLs of the zh/en versions of this page, for hreflang. */
  alternates?: { zh: string; en: string };
}

const { title, description, lang = 'zh', alternates } = Astro.props;
const canonical = alternates ? (lang === 'zh' ? alternates.zh : alternates.en) : undefined;
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {canonical && <link rel="canonical" href={canonical} />}
    {
      alternates && (
        <>
          <link rel="alternate" hreflang="zh-CN" href={alternates.zh} />
          <link rel="alternate" hreflang="en" href={alternates.en} />
          <link rel="alternate" hreflang="x-default" href={alternates.zh} />
        </>
      )
    }
  </head>
  <body>
    <slot />
  </body>
</html>
