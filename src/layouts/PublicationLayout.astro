---
/**
 * Contextual layout (ADR-002 §3): long-form reading mode — CFP, Policies,
 * Guidelines. Narrow measure (65–75 characters), section numbering, and
 * editorial marginalia carry the reading. Chrome comes from PageShell; this
 * layout owns only the `publication` reading treatment (see
 * styles/global.css `.page--publication`).
 */
import PageShell from './PageShell.astro';
import type { RouteKey } from '../lib/routes';
import type { Locale } from '../lib/issueData';

interface Props {
  locale: Locale;
  route: RouteKey;
  issueId: string;
  title: string;
  description: string;
}

const { locale, route, issueId, title, description } = Astro.props;
---

<PageShell
  locale={locale}
  route={route}
  issueId={issueId}
  title={title}
  description={description}
  mode="publication"
>
  <slot />
</PageShell>
