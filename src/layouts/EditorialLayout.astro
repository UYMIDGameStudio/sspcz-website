---
/**
 * The publication document flow: running header (with site navigation),
 * main matter, colophon pinned to the viewport bottom. Both locales render
 * through this single layout — zero duplicated structure (RFC-400 §3).
 * The edition is addressed by ID; nothing here is hardcoded to one issue.
 */
import BaseLayout from './BaseLayout.astro';
import EditorialGrid from '../patterns/EditorialGrid.astro';
import RunningHeader from '../patterns/RunningHeader.astro';
import { t } from '../i18n';
import { getIssueBundle, type Locale } from '../lib/issueData';
import { issueMark } from '../lib/format';
import { path, switchLocale, withBase, type RouteKey } from '../lib/routes';

interface Props {
  locale: Locale;
  route: RouteKey;
  issueId: string;
  title: string;
  description: string;
}

const { locale, route, issueId, title, description } = Astro.props;
const dict = t(locale);
const bundle = getIssueBundle(issueId);

const navItems: Array<{ key: RouteKey; label: string }> = [
  { key: 'home', label: dict.nav.home },
  { key: 'issue', label: dict.nav.currentIssue },
  { key: 'cfp', label: dict.nav.cfp },
  { key: 'program', label: dict.nav.program },
  { key: 'committee', label: dict.nav.committee },
  { key: 'policies', label: dict.nav.policies },
  { key: 'resources', label: dict.nav.resources },
  { key: 'register', label: dict.nav.register },
];

// The logo lockup already carries the full bilingual name, so the wordmark
// beside it stays the short acronym.
const publication = 'SSPCZ';

const alternates = Astro.site
  ? {
      zh: new URL(path('zh', route, issueId), Astro.site).href,
      en: new URL(path('en', route, issueId), Astro.site).href,
    }
  : undefined;
---

<BaseLayout title={title} description={description} lang={locale} alternates={alternates}>
  <EditorialGrid>
    <RunningHeader
      publication={publication}
      issue={issueMark(bundle.issue.issue, locale)}
      year={bundle.issue.year}
      homeHref={path(locale, 'home')}
      logoSrc={withBase('/logo.jpg')}
    >
      {
        navItems.map((item) => (
          <a
            href={path(locale, item.key, issueId)}
            aria-current={item.key === route ? 'page' : undefined}
            class:list={['nav-link', { 'nav-link--active': item.key === route }]}
          >
            {item.label}
          </a>
        ))
      }
      <a class="nav-link nav-link--switch" href={switchLocale(locale, route, issueId)}>
        {dict.nav.languageSwitch}
      </a>
    </RunningHeader>

    <main>
      <slot />
    </main>

    <footer class="colophon" slot="colophon">
      <div class="colophon__imprint">
        <span class="colophon__name">{dict.siteName}</span>
        {locale === 'zh' && <span class="colophon__latin">{dict.siteNameLatin}</span>}
      </div>
      <span class="colophon__rights">{dict.closing.copyright}</span>
    </footer>
  </EditorialGrid>
</BaseLayout>

<style>
  .nav-link {
    display: inline-block;
    padding: var(--space-2) 0;
    color: var(--color-text-muted);
  }

  .nav-link--active {
    color: var(--color-ink);
    border-bottom: 1px solid var(--color-ink);
  }

  .nav-link--switch {
    padding-left: var(--space-4);
    border-left: 1px solid var(--color-line);
  }

  .colophon {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-8);
    align-items: baseline;
    justify-content: space-between;
    padding: var(--space-6) var(--page-gutter);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-on-dark-muted);
    background: var(--color-ink-deep);
  }

  .colophon__imprint {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1) var(--space-4);
    align-items: baseline;
  }

  .colophon__name {
    font-family: var(--font-serif-cjk);
    color: var(--color-text-on-dark);
    letter-spacing: var(--tracking-wide);
  }

  :global(html:lang(en)) .colophon__name {
    font-family: var(--font-serif-latin);
  }

  .colophon__latin,
  .colophon__rights {
    font-family: var(--font-serif-latin);
  }

  @media (width <= 56.25em) {
    .colophon {
      padding: var(--space-6) var(--page-gutter-narrow);
    }
  }
</style>
