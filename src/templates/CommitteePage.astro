---
/** Template: committee & support — organizational registers from YAML. */
import DataLayout from '../layouts/DataLayout.astro';
import Marginalia from '../patterns/Marginalia.astro';
import SectionCounter from '../components/SectionCounter.astro';
import RecordRow from '../components/RecordRow.astro';
import { t } from '../i18n';
import { getIssueBundle, pick, speakerName, type Locale } from '../lib/issueData';
import { issueMark, sessionLabel } from '../lib/format';

interface Props {
  locale: Locale;
  issueId: string;
}

const { locale, issueId } = Astro.props;
const dict = t(locale);
const bundle = getIssueBundle(issueId);
const { committee } = bundle;
const title = `${dict.nav.committee} · ${dict.siteName}`;

const joiner = ' · ';
const listJoiner = locale === 'zh' ? '、' : ', ';

const societyName = (s: (typeof committee.supportingSocieties)[number]): string => {
  if (!s.school) return pick(locale, s.society);
  return locale === 'zh' ? `${s.school.zh}${s.society.zh}` : `${s.society.en}, ${s.school.en}`;
};
const societies = committee.supportingSocieties.map(societyName).join(joiner);
---

<DataLayout locale={locale} route="committee" issueId={issueId} title={title} description={dict.meta.committee}>
  <section class="masthead">
    <p class="masthead__kicker">Organizing Committee · {issueMark(bundle.issue.issue, locale)}</p>
    <h1 class="masthead__title">{dict.nav.committee}</h1>
    <p class="masthead__lead">{dict.committee.lead}</p>
  </section>

  <Marginalia>
    <Fragment slot="margin">
      <SectionCounter label="Structure" />
      <h2>{dict.committee.structureTitle}</h2>
      <p class="margin-sub">Structure of this Session</p>
    </Fragment>
    <div>
      <RecordRow label={dict.committee.labels.hosts}>
        {committee.hosts.map((o) => pick(locale, o.name)).join(joiner)}
      </RecordRow>
      <RecordRow label={dict.committee.labels.coOrganizers}>
        {committee.coOrganizers.map((o) => pick(locale, o.name)).join(joiner)}
        {committee.coOrganizersPending && (
          <span class="pending">{dict.currentIssue.morePending}</span>
        )}
      </RecordRow>
      <RecordRow label={dict.committee.labels.academicSupport}>
        {committee.academicSupport.map((o) => pick(locale, o.name)).join(joiner)}
      </RecordRow>
      <RecordRow label={dict.committee.labels.secretariat}>
        {pick(locale, committee.structure.secretariat)}
      </RecordRow>
      <RecordRow label={dict.committee.labels.teams}>
        <p>{committee.structure.teams.map((o) => pick(locale, o.name)).join(joiner)}</p>
        <p class="team-note">{pick(locale, committee.structure.teamNote)}</p>
      </RecordRow>
    </div>
  </Marginalia>

  <div class="band band--secondary">
    <Marginalia>
      <Fragment slot="margin">
        <SectionCounter label="Societies" />
        <h2>{dict.committee.labels.societies}</h2>
        <p class="margin-sub">Supporting Societies</p>
      </Fragment>
      <p class="societies">{societies}</p>
    </Marginalia>
  </div>

  <Marginalia>
    <Fragment slot="margin">
      <SectionCounter label="Past Sessions" />
      <h2>{dict.committee.pastTitle}</h2>
      <p class="margin-sub">Past Sessions</p>
    </Fragment>
    <div>
      {
        committee.pastSessions.map((s) => (
          <section class="past-session">
            <h3 class="past-session__title">{sessionLabel(s.session, locale)}</h3>
            <RecordRow label={dict.committee.labels.hosts}>
              {s.hosts.map((o) => pick(locale, o.name)).join(listJoiner)}
            </RecordRow>
            {s.coOrganizers && (
              <RecordRow label={dict.committee.labels.coOrganizers}>
                {s.coOrganizers.map((o) => pick(locale, o.name)).join(listJoiner)}
              </RecordRow>
            )}
            <RecordRow label={dict.committee.labels.supporters}>
              {s.supporters.map((o) => pick(locale, o.name)).join(listJoiner)}
            </RecordRow>
          </section>
        ))
      }
    </div>
  </Marginalia>

  <Marginalia>
    <Fragment slot="margin">
      <SectionCounter label="Speakers" />
      <h2>{dict.committee.speakersTitle}</h2>
      <p class="margin-sub">Past Guest Speakers</p>
    </Fragment>
    <div>
      <ul class="speakers">
        {bundle.speakers.pastSpeakers.map((s) => <li class="speakers__name">{speakerName(locale, s)}</li>)}
      </ul>
      <p class="speakers__note">{pick(locale, bundle.speakers.pastSpeakersNote)}</p>
    </div>
  </Marginalia>

  <div class="band band--ink">
    <div class="partnership">
      <p class="partnership__tag">Partnership</p>
      <p class="partnership__title">{dict.committee.partnershipTitle}</p>
      <p class="partnership__lead">{pick(locale, committee.partnership.invitation)}</p>
      <p class="partnership__contact">
        <a href={`mailto:${committee.partnership.email}`}>{committee.partnership.email}</a>
      </p>
    </div>
  </div>
</DataLayout>

<style>
  .pending {
    margin-left: var(--space-1);
    color: var(--color-text-muted);
  }

  .team-note {
    margin-top: var(--space-1);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .societies {
    font-size: var(--type-metadata);
    line-height: var(--leading-loose);
    color: var(--color-ink);
  }

  .past-session {
    padding-bottom: var(--space-6);
  }

  .past-session + .past-session {
    margin-top: var(--space-6);
    border-top: 1px solid var(--color-line);
    padding-top: var(--space-6);
  }

  .past-session__title {
    font-size: var(--text-md);
  }

  .speakers {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .speakers__name {
    padding: var(--space-3) var(--space-6);
    font-family: var(--font-serif-cjk);
    font-size: var(--type-heading-sub);
    color: var(--color-ink);
    border: 1px solid var(--color-line-strong);
  }

  :global(html:lang(en)) .speakers__name {
    font-family: var(--font-serif-latin);
  }

  .speakers__note {
    margin-top: var(--space-4);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  /* Dark partnership band. */
  .partnership {
    max-width: var(--page-max);
    margin-inline: auto;
    padding: var(--space-16) var(--page-gutter);
    text-align: center;
  }

  .partnership__tag {
    font-family: var(--font-serif-latin);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wider);
    color: var(--color-text-on-dark-muted);
    text-transform: uppercase;
  }

  .partnership__title {
    margin-top: var(--space-3);
    font-family: var(--font-serif-cjk);
    font-size: var(--text-lg);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-on-dark);
  }

  :global(html:lang(en)) .partnership__title {
    font-family: var(--font-serif-latin);
  }

  .partnership__lead {
    max-width: 34em;
    margin: var(--space-4) auto 0;
    line-height: var(--leading-normal);
    color: var(--color-text-on-dark-muted);
  }

  .partnership__contact {
    margin-top: var(--space-6);
    font-family: var(--font-serif-latin);
    font-size: var(--text-md);
    letter-spacing: var(--tracking-wide);
  }

  .partnership__contact a {
    color: var(--color-text-on-dark);
    text-decoration: underline;
  }
</style>
