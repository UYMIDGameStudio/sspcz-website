---
/**
 * Template: registration — a native HTML form (RFC-400 §1 Zero-JS
 * baseline). Radio choices and submission work with JavaScript disabled;
 * the backend behind /api/register is a separate decision (ADR-001 §6).
 */
import DataLayout from '../layouts/DataLayout.astro';
import Marginalia from '../patterns/Marginalia.astro';
import SectionCounter from '../components/SectionCounter.astro';
import { t } from '../i18n';
import { getIssueBundle, type Locale } from '../lib/issueData';
import { dateRange, issueMark, quotedTheme } from '../lib/format';
import { path } from '../lib/routes';

interface Props {
  locale: Locale;
  issueId: string;
}

const { locale, issueId } = Astro.props;
const dict = t(locale);
const bundle = getIssueBundle(issueId);
const r = dict.register;
const title = `${dict.nav.register} · ${dict.siteName}`;
---

<DataLayout locale={locale} route="register" issueId={issueId} title={title} description={dict.meta.register}>
  <section class="masthead">
    <p class="masthead__kicker">Registration · {issueMark(bundle.issue.issue, locale)}</p>
    <h1 class="masthead__title">{dict.nav.register}</h1>
    <p class="masthead__theme">
      {dateRange(bundle.issue.dates.start, bundle.issue.dates.end, locale)} ·
      {quotedTheme(locale, bundle.issue.theme)}
    </p>
    <p class="masthead__lead">{r.lead}</p>
  </section>

  <Marginalia>
    <Fragment slot="margin">
      <SectionCounter label="Registration" />
      <h2>{dict.nav.register}</h2>
      <p class="margin-note">
        {r.cfpNote}
        <a href={path(locale, 'cfp', issueId)}>{dict.nav.cfp}</a>
      </p>
      <p class="margin-note">
        {r.contactLabel} ·
        <a href={`mailto:${bundle.issue.contact.email}`}>{bundle.issue.contact.email}</a>
      </p>
    </Fragment>

    <form class="register-form" method="post" action="/api/register">
      <input type="hidden" name="lang" value={locale} />

      <div class="register-form__grid">
        <label class="field">
          <span class="field__label">
            {r.fields.name} <span class="field__req" aria-hidden="true">*</span>
          </span>
          <input name="name" required autocomplete="name" placeholder={r.placeholders.name} />
        </label>

        <label class="field">
          <span class="field__label">
            {r.fields.school} <span class="field__req" aria-hidden="true">*</span>
          </span>
          <input name="school" required placeholder={r.placeholders.school} />
        </label>

        <label class="field">
          <span class="field__label">
            {r.fields.grade} <span class="field__req" aria-hidden="true">*</span>
          </span>
          <select name="grade" required>
            <option value="">{r.placeholders.grade}</option>
            {r.options.grades.map((g) => <option value={g}>{g}</option>)}
          </select>
        </label>

        <label class="field">
          <span class="field__label">
            {r.fields.contact} <span class="field__req" aria-hidden="true">*</span>
          </span>
          <input name="contact" required placeholder={r.placeholders.contact} />
        </label>
      </div>

      <fieldset class="choices">
        <legend class="choices__legend">
          {r.fields.attendance} <span class="field__req" aria-hidden="true">*</span>
        </legend>
        <label class="choice">
          <input type="radio" name="attendance" value="offline" required />
          <span class="choice__label">{r.options.attendanceOffline}</span>
        </label>
        <label class="choice">
          <input type="radio" name="attendance" value="online" required />
          <span class="choice__label">{r.options.attendanceOnline}</span>
        </label>
      </fieldset>

      <fieldset class="choices">
        <legend class="choices__legend">
          {r.fields.role} <span class="field__req" aria-hidden="true">*</span>
        </legend>
        <label class="choice">
          <input type="radio" name="role" value="auditor" required />
          <span class="choice__label">{r.options.roleAuditor}</span>
        </label>
        <label class="choice">
          <input type="radio" name="role" value="submitter" required />
          <span class="choice__label">{r.options.roleSubmitter}</span>
        </label>
      </fieldset>

      <label class="field">
        <span class="field__label">{r.fields.notes}</span>
        <textarea name="notes" rows="3" placeholder={r.placeholders.notes}></textarea>
      </label>

      <button class="register-form__submit" type="submit">{r.submit}</button>
    </form>
  </Marginalia>
</DataLayout>

<style>
  .margin-note {
    margin-top: var(--space-4);
    font-size: var(--text-xs);
    line-height: var(--leading-loose);
    color: var(--color-text-muted);
  }

  .margin-note a {
    color: var(--color-text-muted);
    text-decoration: underline;
  }

  .register-form {
    max-width: var(--measure);
  }

  .register-form__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
  }

  .field {
    display: block;
  }

  .field + .field {
    margin-top: var(--space-6);
  }

  .field__label {
    display: block;
    margin-bottom: var(--space-2);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
  }

  .field__req {
    color: var(--color-alert);
  }

  .field input,
  .field select,
  .field textarea {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-sans-cjk);
    font-size: var(--text-sm);
    color: var(--color-ink);
    background: var(--color-surface);
    border: 1px solid var(--color-line-strong);
  }

  .field input:focus-visible,
  .field select:focus-visible,
  .field textarea:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -1px;
  }

  .field textarea {
    resize: vertical;
  }

  .choices {
    margin: var(--space-8) 0 0;
    padding: 0;
    border: 0;
  }

  .choices__legend {
    padding: 0;
    margin-bottom: var(--space-2);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
  }

  .choice {
    display: inline-block;
    margin-right: var(--space-3);
  }

  .choice input {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
  }

  .choice__label {
    display: inline-block;
    padding: var(--space-3) var(--space-6);
    font-size: var(--text-sm);
    color: var(--color-text);
    cursor: pointer;
    background: var(--color-surface);
    border: 1px solid var(--color-line-strong);
  }

  .choice input:checked + .choice__label {
    font-weight: 600;
    color: var(--color-text-on-dark);
    background: var(--color-ink);
    border-color: var(--color-ink);
  }

  .choice input:focus-visible + .choice__label {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .register-form > .field {
    margin-top: var(--space-8);
  }

  .register-form__submit {
    width: 100%;
    padding: var(--space-4);
    margin-top: var(--space-8);
    font-family: var(--font-sans-cjk);
    font-size: var(--text-base);
    font-weight: 600;
    letter-spacing: var(--tracking-wider);
    color: var(--color-text-on-dark);
    cursor: pointer;
    background: var(--color-ink);
    border: 0;
  }

  .register-form__submit:hover {
    background: var(--color-accent);
  }

  .register-form__submit:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  @media (width <= 56.25em) {
    .register-form__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
