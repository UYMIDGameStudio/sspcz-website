---
/** Template: Call for Papers — editorial document + timeline records. */
import { getEntry, render } from 'astro:content';
import EditorialLayout from '../layouts/EditorialLayout.astro';
import Marginalia from '../patterns/Marginalia.astro';
import SectionCounter from '../components/SectionCounter.astro';
import RecordRow from '../components/RecordRow.astro';
import { t } from '../i18n';
import { getIssueBundle, type Locale } from '../lib/issueData';
import { dateRange, issueMark, monthYear, quotedTheme } from '../lib/format';

interface Props {
  locale: Locale;
  issueId: string;
}

const { locale, issueId } = Astro.props;
const dict = t(locale);
const bundle = getIssueBundle(issueId);

const entry = await getEntry('conference', `${issueId}/cfp.${locale}`);
if (!entry) throw new Error(`${issueId} cfp document missing`);
const { Content } = await render(entry);

const title = `${entry.data.title} · ${dict.siteName}`;
---

<EditorialLayout locale={locale} route="cfp" issueId={issueId} title={title} description={dict.meta.cfp}>
  <section class="masthead">
    <p class="masthead__kicker">Call for Papers · {issueMark(bundle.issue.issue, locale)}</p>
    <h1 class="masthead__title">{entry.data.title}</h1>
    <p class="masthead__theme">
      {dict.currentIssue.themeLabel} · {quotedTheme(locale, bundle.issue.theme)}
    </p>
  </section>

  <Marginalia>
    <Fragment slot="margin">
      <SectionCounter label="Dates" />
      <div>
        <RecordRow label={dict.cfpMeta.open}>{monthYear(bundle.issue.cfp.open, locale)}</RecordRow>
        <RecordRow label={dict.cfpMeta.deadline}>
          {monthYear(bundle.issue.cfp.deadline, locale)}
        </RecordRow>
        <RecordRow label={dict.cfpMeta.presentations}>
          {dateRange(bundle.issue.cfp.presentations.start, bundle.issue.cfp.presentations.end, locale)}
        </RecordRow>
        <RecordRow label={dict.register.contactLabel}>
          <a href={`mailto:${bundle.issue.contact.email}`}>{bundle.issue.contact.email}</a>
        </RecordRow>
      </div>
    </Fragment>
    <div class="prose"><Content /></div>
  </Marginalia>
</EditorialLayout>
