---
/**
 * Template: the Institutional Cover (`/`, `/en/`) — the institution's front
 * door (ADR-003 §3.6, Q6). It is a ceremonial, sparse scholarly cover, not
 * a portal or content dashboard: the institutional lockup, the current
 * edition's identity plate (EditionCard on ice-blue contextual paper), and
 * a minimal set of portals. The full About prose and archive listing live
 * on their own routes (ADR-003 §3.5/§3.6), never on the cover.
 *
 * Zero-code-change constraint: the current edition is resolved through the
 * `currentIssue` pointer in src/data/institution.yaml — publishing a new
 * edition never touches this template.
 */
import LandingLayout from '../layouts/LandingLayout.astro';
import EditionCard from '../components/EditionCard.astro';
import { t } from '../i18n';
import {
  currentIssueId,
  getIssueBundle,
  institution,
  type Locale,
} from '../lib/issueData';
import { issueTitle } from '../lib/format';
import { path } from '../lib/routes';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);

/* Current edition — resolved dynamically via the institutional pointer. */
const current = getIssueBundle(currentIssueId);

const title = `${dict.siteName} · ${dict.siteNameLatin}`;
---

<LandingLayout
  locale={locale}
  route="home"
  issueId={currentIssueId}
  title={title}
  description={dict.meta.home}
>
  <section class="cover">
    <div class="cover__masthead">
      <p class="cover__kicker">{dict.home.coverKicker}</p>
      <h1 class="cover__title">{dict.siteName}</h1>
      <p class="cover__identity">
        <span class="cover__est">EST. {institution.founded}</span>
        <span class="cover__rule" aria-hidden="true"></span>
        <span class="cover__tagline">{dict.home.tagline}</span>
      </p>
    </div>

    <EditionCard
      n={current.issue.issue}
      locale={locale}
      href={path(locale, 'issue', currentIssueId)}
      theme={current.issue.theme}
      year={current.issue.year}
      title={issueTitle(current.issue.issue, locale, dict.siteName)}
      cta={dict.actions.viewDetails}
    />

    <nav class="cover__portals" aria-label={dict.home.currentTitle}>
      <a class="cover__portal" href={path(locale, 'issue', currentIssueId)}>
        <span class="cover__portal-tag">About</span>
        <span class="cover__portal-label">{dict.nav.home} →</span>
      </a>
      <a class="cover__portal" href={path(locale, 'archive')}>
        <span class="cover__portal-tag">Archive</span>
        <span class="cover__portal-label">{dict.nav.archive} →</span>
      </a>
      <a class="cover__portal" href={path(locale, 'register', currentIssueId)}>
        <span class="cover__portal-tag">Register</span>
        <span class="cover__portal-label">{dict.nav.register} →</span>
      </a>
    </nav>
  </section>
</LandingLayout>

<style>
  .cover {
    max-width: var(--page-max);
    margin: 0 auto;
    padding: var(--space-24) var(--page-gutter);
  }

  /* --- masthead: institutional identity --- */
  .cover__kicker {
    font-family: var(--font-serif-latin);
    font-size: var(--type-marginalia);
    letter-spacing: var(--tracking-wider);
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .cover__title {
    max-width: 11em;
    margin-top: var(--space-6);
    font-family: var(--font-serif-cjk);
    font-weight: var(--weight-bold);
    font-size: var(--type-display);
    line-height: var(--leading-none);
    color: var(--color-ink);
  }

  :global(html:lang(en)) .cover__title {
    font-family: var(--font-serif-latin);
  }

  .cover__identity {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-4) var(--space-6);
    margin-top: var(--space-8);
    color: var(--color-text-muted);
  }

  .cover__est {
    font-family: var(--font-serif-latin);
    font-size: var(--type-metadata);
    letter-spacing: var(--tracking-wide);
  }

  .cover__rule {
    width: 7.5rem;
    height: 1px;
    background: var(--color-line-strong);
  }

  .cover__tagline {
    font-size: var(--type-metadata);
  }

  :global(html:lang(en)) .cover__tagline {
    font-family: var(--font-serif-latin);
  }

  /* --- portals: minimal navigation to the institution's other surfaces --- */
  .cover__portals {
    display: flex;
    margin-top: var(--space-16);
    border-top: 1px solid var(--color-line);
  }

  .cover__portal {
    flex: 1;
    padding: var(--space-8) var(--space-8) 0 var(--space-8);
    border-left: 1px solid var(--color-line);
  }

  .cover__portal:first-child {
    padding-left: 0;
    border-left: 0;
  }

  .cover__portal-tag {
    display: block;
    font-family: var(--font-serif-latin);
    font-size: var(--type-marginalia);
    letter-spacing: var(--tracking-wider);
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .cover__portal-label {
    display: block;
    margin-top: var(--space-3);
    font-family: var(--font-serif-cjk);
    font-size: var(--type-heading-sub);
    color: var(--color-ink);
  }

  :global(html:lang(en)) .cover__portal-label {
    font-family: var(--font-serif-latin);
  }

  .cover__portal:hover .cover__portal-label {
    color: var(--color-accent);
  }

  @media (width <= 56.25em) {
    .cover {
      padding: var(--space-16) var(--page-gutter-narrow);
    }

    .cover__title {
      font-size: var(--text-2xl);
    }

    .cover__portals {
      flex-direction: column;
    }

    .cover__portal {
      padding: var(--space-6) 0 0;
      border-left: 0;
    }

    .cover__portal + .cover__portal {
      margin-top: var(--space-6);
      border-top: 1px solid var(--color-line);
    }
  }
</style>
