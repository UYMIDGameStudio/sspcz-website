---
/**
 * Template: the institutional Archive (ADR-002 §1, Q2) — a standalone L1
 * register of every session. Two archival sources, deduplicated by session
 * number: editions published on this platform (issue bundles, linked to
 * their permanent homes, newest first) and the committee's pastSessions
 * record — the SSOT for editions that predate the platform. Extending the
 * archive is a data-only change (a new issue folder, or a new pastSessions
 * entry), never a template edit.
 */
import DataLayout from '../layouts/DataLayout.astro';
import Marginalia from '../patterns/Marginalia.astro';
import SectionCounter from '../components/SectionCounter.astro';
import RecordRow from '../components/RecordRow.astro';
import { t } from '../i18n';
import {
  currentIssue,
  currentIssueId,
  getIssueBundle,
  institution,
  issueIds,
  pick,
  type Locale,
} from '../lib/issueData';
import { issueTitle, paddedIssue, quotedTheme, sessionLabel } from '../lib/format';
import { path } from '../lib/routes';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
const labels = dict.committee.labels;
const joiner = locale === 'zh' ? '、' : ', ';

interface Row {
  label: string;
  value: string;
}
interface Edition {
  n: number;
  year: number;
  current: boolean;
  href?: string;
  theme?: { zh: string; en: string };
  summary?: string;
  rows: Row[];
}

const names = (list?: { name: { zh: string; en: string } }[]) =>
  list ? list.map((o) => pick(locale, o.name)).join(joiner) : '';

/* Platform editions — linked to their permanent homes. */
const platformEditions: Edition[] = issueIds.map((id) => {
  const b = getIssueBundle(id);
  return {
    n: b.issue.issue,
    year: b.issue.year,
    current: id === currentIssueId,
    href: path(locale, 'issue', id),
    theme: b.issue.theme,
    rows: [
      { label: labels.hosts, value: names(b.committee.hosts) },
      { label: labels.coOrganizers, value: names(b.committee.coOrganizers) },
      { label: labels.academicSupport, value: names(b.committee.academicSupport) },
    ],
  };
});

/* Pre-platform editions — the committee's archival record. */
const platformNumbers = new Set(platformEditions.map((e) => e.n));
const pastEditions: Edition[] = currentIssue.committee.pastSessions
  .filter((s) => !platformNumbers.has(s.session))
  .map((s) => {
    const rows: Row[] = [{ label: labels.hosts, value: names(s.hosts) }];
    if (s.coOrganizers) rows.push({ label: labels.coOrganizers, value: names(s.coOrganizers) });
    rows.push({ label: labels.supporters, value: names(s.supporters) });
    return {
      n: s.session,
      year: institution.founded + (s.session - 1),
      current: false,
      summary: pick(locale, s.summary),
      rows,
    };
  });

const editions = [...platformEditions, ...pastEditions].sort((a, b) => b.n - a.n);
const title = `${dict.nav.archive} · ${dict.siteName}`;
---

<DataLayout
  locale={locale}
  route="archive"
  issueId={currentIssueId}
  title={title}
  description={dict.archive.metaDescription}
>
  <section class="masthead">
    <p class="masthead__kicker">Archive · Since {institution.founded}</p>
    <h1 class="masthead__title">{dict.nav.archive}</h1>
    <p class="masthead__lead">{dict.archive.lead}</p>
  </section>

  {
    editions.map((e) => (
      <div class:list={[{ 'band band--secondary': e.current }]}>
        <Marginalia>
          <Fragment slot="margin">
            <SectionCounter label={`${e.year}`} />
            <p class="edition__numeral" aria-hidden="true">
              {paddedIssue(e.n)}
            </p>
            <h2 class="edition__title">{issueTitle(e.n, locale, dict.siteName)}</h2>
            <p class="margin-sub">{sessionLabel(e.n, 'en')} · {e.year}</p>
          </Fragment>
          <div>
            {e.theme && (
              <p class="edition__theme">
                {dict.currentIssue.themeLabel} · {quotedTheme(locale, e.theme)}
              </p>
            )}
            {e.summary && <p class="edition__summary">{e.summary}</p>}
            {e.rows.map((r) => (
              <RecordRow label={r.label}>{r.value}</RecordRow>
            ))}
            {e.href && (
              <p class="edition__enter">
                {e.current && <span class="edition__mark">{dict.home.currentMark}</span>}
                <a href={e.href}>{dict.actions.viewDetails} →</a>
              </p>
            )}
          </div>
        </Marginalia>
      </div>
    ))
  }
</DataLayout>

<style>
  .edition__numeral {
    margin-top: var(--space-3);
    font-family: var(--font-serif-latin);
    font-size: var(--text-2xl);
    line-height: var(--leading-none);
    color: var(--color-ink);
  }

  .edition__title {
    margin-top: var(--space-2);
    font-size: var(--type-heading-sub);
  }

  .edition__theme {
    padding-bottom: var(--space-4);
    font-family: var(--font-serif-cjk);
    font-size: var(--text-md);
    color: var(--color-ink);
  }

  :global(html:lang(en)) .edition__theme {
    font-family: var(--font-serif-latin);
  }

  .edition__summary {
    max-width: var(--measure);
    padding-bottom: var(--space-4);
    color: var(--color-text);
    line-height: var(--leading-loose);
  }

  .edition__enter {
    display: flex;
    gap: var(--space-4);
    align-items: baseline;
    margin-top: var(--space-6);
    font-size: var(--type-metadata);
  }

  .edition__enter a {
    color: var(--color-accent-deep);
    text-decoration: underline;
  }

  .edition__mark {
    padding: var(--space-1) var(--space-3);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
    border: 1px solid var(--color-line-strong);
  }
</style>
