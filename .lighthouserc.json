{
  "ci": {
    "collect": {
      "startServerCommand": "node scripts/qa-server.mjs",
      "startServerReadyPattern": "qa server ready",
      "numberOfRuns": 1,
      "url": [
        "http://localhost:4173/sspcz-website/",
        "http://localhost:4173/sspcz-website/en/",
        "http://localhost:4173/sspcz-website/issue-003/",
        "http://localhost:4173/sspcz-website/issue-003/cfp/",
        "http://localhost:4173/sspcz-website/issue-003/program/",
        "http://localhost:4173/sspcz-website/issue-003/committee/",
        "http://localhost:4173/sspcz-website/issue-003/policies/",
        "http://localhost:4173/sspcz-website/issue-003/register/",
        "http://localhost:4173/sspcz-website/en/issue-003/",
        "http://localhost:4173/sspcz-website/en/issue-003/cfp/",
        "http://localhost:4173/sspcz-website/en/issue-003/program/",
        "http://localhost:4173/sspcz-website/en/issue-003/committee/",
        "http://localhost:4173/sspcz-website/en/issue-003/policies/",
        "http://localhost:4173/sspcz-website/en/issue-003/register/"
      ],
      "settings": {
        "chromeFlags": "--no-sandbox --disable-dev-shm-usage"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.95 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.95 }],
        "categories:seo": ["error", { "minScore": 0.95 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci/reports"
    }
  }
}
